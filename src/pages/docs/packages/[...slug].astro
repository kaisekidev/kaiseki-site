---
import { getCollection, render, type CollectionEntry } from 'astro:content'
import DocsLayout from '@/layouts/DocsLayout.astro'
import { getNavModel, prevNext } from '@/lib/docs'

export async function getStaticPaths() {
  const model = await getNavModel()
  const readmeEntries = await getCollection('packageReadmes')
  const docEntries = await getCollection('packageDocs')

  const byKey = new Map<string, CollectionEntry<'packageReadmes'> | CollectionEntry<'packageDocs'>>()
  for (const e of readmeEntries) byKey.set(`packageReadmes:${e.id}`, e)
  for (const e of docEntries) byKey.set(`packageDocs:${e.id}`, e)

  const paths = []
  for (const groupNav of model.groups) {
    for (const pkgNav of groupNav.packages) {
      // Package overview (README).
      const readme = byKey.get(`packageReadmes:${pkgNav.page.entryId}`)
      if (readme) {
        paths.push({
          params: { slug: pkgNav.page.slug },
          props: {
            entry: readme,
            title: pkgNav.page.title,
            eyebrow: groupNav.group.title,
            description: pkgNav.pkg.description,
            ...prevNext(model, pkgNav.page.slug),
          },
        })
      }
      // Individual docs pages.
      for (const doc of pkgNav.docs) {
        const entry = byKey.get(`packageDocs:${doc.entryId}`)
        if (!entry) continue
        paths.push({
          params: { slug: doc.slug },
          props: {
            entry,
            title: doc.title,
            eyebrow: pkgNav.pkg.title,
            description: pkgNav.pkg.description,
            ...prevNext(model, doc.slug),
          },
        })
      }
    }
  }
  return paths
}

const { entry, title, eyebrow, description, prev, next } = Astro.props
const { Content, headings } = await render(entry)
---

<DocsLayout
  title={title}
  eyebrow={eyebrow}
  description={description}
  headings={headings}
  prev={prev}
  next={next}
>
  <Content />
</DocsLayout>
