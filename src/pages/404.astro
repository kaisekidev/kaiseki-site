---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Button from '@/components/Button.astro'
---

<BaseLayout title="Page not found — Kaiseki">
  <div class="min-w-0 max-w-2xl flex-auto px-4 py-16 lg:max-w-none lg:pl-8 lg:pr-0 xl:px-16">
    <div class="flex h-full flex-col items-center justify-center text-center">
      <p class="font-display text-sm font-medium text-red-500">404</p>
      <h1 class="mt-3 font-display text-3xl tracking-tight text-neutral-900 dark:text-paper">
        Page not found
      </h1>
      <p class="mt-3 text-base text-neutral-600 dark:text-neutral-400">
        Sorry, we couldn’t find the page you’re looking for.
      </p>
      <Button href={import.meta.env.BASE_URL} class="mt-8">Back to home</Button>
    </div>
  </div>
</BaseLayout>
