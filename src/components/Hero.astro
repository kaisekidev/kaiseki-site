---
import { Image } from 'astro:assets'
import { Code } from 'astro:components'
import Button from './Button.astro'
import HeroBackground from './HeroBackground.astro'
import blurCyan from '@/assets/blur-cyan.png'
import blurIndigo from '@/assets/blur-indigo.png'

interface Props {
  primaryHref: string
  githubHref: string
}
const { primaryHref, githubHref } = Astro.props

const code = `$container = (new ContainerBuilder(
    require __DIR__ . '/config-providers.php',
))
    ->withConfigFolder(__DIR__ . '/config')
    ->build();`
---

<div class="overflow-hidden bg-neutral-900 dark:-mb-32 dark:mt-[-4.75rem] dark:pb-32 dark:pt-[4.75rem]">
  <div class="py-16 sm:px-2 lg:relative lg:px-0 lg:py-20">
    <div class="mx-auto grid max-w-2xl grid-cols-1 items-center gap-x-8 gap-y-16 px-4 lg:max-w-8xl lg:grid-cols-2 lg:px-8 xl:gap-x-16 xl:px-12">
      <div class="relative z-10 md:text-center lg:text-left">
        <Image class="absolute bottom-full right-full -mb-56 -mr-72 opacity-50" src={blurCyan} alt="" width={530} height={530} />
        <div class="relative">
          <p class="inline bg-gradient-to-r from-indigo-200 via-red-400 to-indigo-200 bg-clip-text font-display text-5xl tracking-normal text-transparent">
            Modern building blocks for WordPress.
          </p>
          <p class="mt-3 text-2xl tracking-normal text-neutral-400">
            A suite of small, type-safe, framework-agnostic PHP packages — dependency injection,
            configuration and WordPress helpers that compose cleanly together.
          </p>
          <div class="mt-8 flex gap-4 md:justify-center lg:justify-start">
            <Button href={primaryHref}>Get started</Button>
            <Button href={githubHref} variant="secondary">View on GitHub</Button>
          </div>
        </div>
      </div>
      <div class="relative lg:static xl:pl-10">
        <div class="absolute inset-x-[-50vw] -bottom-48 -top-32 [mask-image:linear-gradient(transparent,white,white)] lg:-bottom-32 lg:-top-32 lg:left-[calc(50%+14rem)] lg:right-0 lg:[mask-image:none] dark:[mask-image:linear-gradient(transparent,white,transparent)] lg:dark:[mask-image:linear-gradient(white,white,transparent)]">
          <HeroBackground class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 lg:left-0 lg:translate-x-0 lg:translate-y-[-60%]" />
        </div>
        <div class="relative">
          <Image class="absolute -right-64 -top-64" src={blurCyan} alt="" width={530} height={530} />
          <Image class="absolute -bottom-40 -right-44" src={blurIndigo} alt="" width={567} height={567} />
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-tr from-red-300 via-red-300/70 to-blue-300 opacity-10 blur-lg"></div>
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-tr from-red-300 via-red-300/70 to-blue-300 opacity-10"></div>
          <div class="relative rounded-2xl bg-[#0A101F]/80 ring-1 ring-white/10 backdrop-blur">
            <div class="absolute -top-px left-20 right-11 h-px bg-gradient-to-r from-red-300/0 via-red-300/70 to-red-300/0"></div>
            <div class="absolute -bottom-px left-11 right-20 h-px bg-gradient-to-r from-blue-400/0 via-blue-400 to-blue-400/0"></div>
            <div class="pl-4 pt-4">
              <svg aria-hidden="true" viewBox="0 0 42 10" fill="none" class="h-2.5 w-auto stroke-neutral-500/30">
                <circle cx="5" cy="5" r="4.5"></circle>
                <circle cx="21" cy="5" r="4.5"></circle>
                <circle cx="37" cy="5" r="4.5"></circle>
              </svg>
              <div class="mt-4 flex space-x-2 text-xs">
                <div class="flex h-6 rounded-full bg-gradient-to-r from-red-400/30 via-red-400 to-red-400/30 p-px font-medium text-red-300">
                  <div class="flex items-center rounded-full px-2.5 bg-neutral-800">functions.php</div>
                </div>
                <div class="flex h-6 rounded-full text-neutral-500">
                  <div class="flex items-center rounded-full px-2.5">composer.json</div>
                </div>
              </div>
              <div class="mt-6 flex items-start px-1 text-sm">
                <div aria-hidden="true" class="select-none border-r border-neutral-300/5 pr-4 font-mono text-neutral-600">
                  {Array.from({ length: code.split('\n').length }).map((_, i) => (
                    <Fragment>{(i + 1).toString().padStart(2, '0')}<br /></Fragment>
                  ))}
                </div>
                <div class="hero-code w-full overflow-x-auto pb-6 pl-4">
                  <Code code={code} lang="php" theme="github-dark" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .hero-code pre {
    background: transparent !important;
    margin: 0;
  }
</style>
