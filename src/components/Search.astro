---
// Search is powered by Pagefind, which indexes the built static site.
// The index + UI assets live under `<base>/pagefind/` (generated by the
// `pagefind` postbuild step; served in dev by the astro-pagefind integration).
const bundlePath = import.meta.env.BASE_URL.replace(/\/?$/, '/') + 'pagefind/'
---

<button
  type="button"
  data-search-open
  class="group flex h-6 w-6 items-center justify-center sm:justify-start md:h-auto md:w-80 md:flex-none md:rounded-lg md:py-2.5 md:pl-4 md:pr-3.5 md:text-sm md:ring-1 md:ring-neutral-200 md:hover:ring-neutral-300 lg:w-96 dark:md:bg-neutral-800/75 dark:md:ring-inset dark:md:ring-white/5 dark:md:hover:bg-neutral-700/40 dark:md:hover:ring-neutral-500"
>
  <svg aria-hidden="true" viewBox="0 0 20 20" class="h-5 w-5 flex-none fill-neutral-400 group-hover:fill-neutral-500 dark:fill-neutral-500 md:group-hover:fill-neutral-400">
    <path d="M16.293 17.707a1 1 0 0 0 1.414-1.414l-1.414 1.414ZM9 14a5 5 0 0 1-5-5H2a7 7 0 0 0 7 7v-2ZM4 9a5 5 0 0 1 5-5V2a7 7 0 0 0-7 7h2Zm5-5a5 5 0 0 1 5 5h2a7 7 0 0 0-7-7v2Zm8.707 12.293-3.757-3.757-1.414 1.414 3.757 3.757 1.414-1.414ZM14 9a4.98 4.98 0 0 1-1.464 3.536l1.414 1.414A6.98 6.98 0 0 0 16 9h-2Zm-1.464 3.536A4.98 4.98 0 0 1 9 14v2a6.98 6.98 0 0 0 4.95-2.05l-1.414-1.414Z" />
  </svg>
  <span class="sr-only md:not-sr-only md:ml-2 md:text-neutral-500 md:dark:text-neutral-400">Search docs</span>
  <kbd class="ml-auto hidden font-medium text-neutral-400 md:block dark:text-neutral-500">
    <kbd class="font-sans">⌘</kbd><kbd class="font-sans">K</kbd>
  </kbd>
</button>

<dialog
  data-search-dialog
  class="fixed inset-0 z-50 m-0 h-full max-h-none w-full max-w-none bg-transparent backdrop:bg-neutral-400/25 backdrop:backdrop-blur dark:backdrop:bg-black/40"
>
  <div class="mx-auto mt-16 max-w-xl px-4">
    <div class="overflow-hidden rounded-lg bg-paper shadow-xl ring-1 ring-neutral-900/10 dark:bg-neutral-900 dark:ring-white/10">
      <div id="pagefind-search" class="p-2"></div>
    </div>
  </div>
</dialog>

<link rel="stylesheet" href={`${bundlePath}pagefind-ui.css`} />

<style is:global>
  /* Tailor Pagefind's default UI to the Syntax red/dark theme. */
  #pagefind-search {
    --pagefind-ui-primary: var(--color-red-500);
    --pagefind-ui-text: var(--color-neutral-700);
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: var(--color-neutral-200);
    --pagefind-ui-tag: var(--color-neutral-100);
    --pagefind-ui-border-radius: 0.5rem;
    --pagefind-ui-font: var(--font-sans);
  }
  .dark #pagefind-search {
    --pagefind-ui-text: var(--color-neutral-200);
    --pagefind-ui-border: var(--color-neutral-700);
    --pagefind-ui-tag: var(--color-neutral-800);
  }
</style>

<script define:vars={{ bundlePath }}>
  function initSearch() {
    const openBtn = document.querySelector('[data-search-open]')
    const dialog = document.querySelector('[data-search-dialog]')
    if (!openBtn || !dialog) return

    let initialized = false

    async function ensureUI() {
      if (initialized) return
      initialized = true
      try {
        // pagefind-ui.js is an IIFE bundle, not an ES module: it assigns the
        // constructor to window.PagefindUI and exports nothing. Import it for
        // its side effect, then read the global (destructuring the module
        // namespace yields undefined → "PagefindUI is not a constructor").
        await import(/* @vite-ignore */ `${bundlePath}pagefind-ui.js`)
        const PagefindUI = window.PagefindUI
        if (typeof PagefindUI !== 'function') {
          throw new Error('window.PagefindUI was not defined after loading pagefind-ui.js')
        }
        new PagefindUI({
          element: '#pagefind-search',
          bundlePath,
          showSubResults: true,
          showImages: false,
        })
      } catch (err) {
        initialized = false
        console.warn('Pagefind failed to initialize (search is only available in a built site).', err)
      }
    }

    function open() {
      ensureUI()
      dialog.showModal()
      setTimeout(() => dialog.querySelector('input')?.focus(), 50)
    }
    function close() {
      dialog.close()
    }

    openBtn.addEventListener('click', open)
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) close()
    })
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault()
        dialog.open ? close() : open()
      }
    })
  }

  initSearch()
  document.addEventListener('astro:after-swap', initSearch)
</script>
