---
interface Props {
  variant?: 'primary' | 'secondary'
  href?: string
  class?: string
}

const variantStyles = {
  primary:
    'rounded-full bg-red-300 py-2 px-4 text-sm font-semibold text-neutral-900 hover:bg-red-200 focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-300/50 active:bg-red-500',
  secondary:
    'rounded-full bg-neutral-800 py-2 px-4 text-sm font-medium text-white hover:bg-neutral-700 focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white/50 active:text-neutral-400',
}

const { variant = 'primary', href, class: className } = Astro.props
const cls = [variantStyles[variant], className]
---

{
  href ? (
    <a href={href} class:list={cls}>
      <slot />
    </a>
  ) : (
    <button class:list={cls}>
      <slot />
    </button>
  )
}
