---
import Navigation from './Navigation.astro'
import Logo from './Logo.astro'
import Logomark from './Logomark.astro'
---

<button type="button" data-mobile-nav-open aria-label="Open navigation" class="relative">
  <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6 stroke-neutral-900 dark:stroke-neutral-200">
    <path d="M3 6h18M3 12h18M3 18h18" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
  </svg>
</button>

<dialog
  data-mobile-nav-dialog
  class="fixed inset-0 z-50 m-0 h-full max-h-none w-full max-w-none bg-transparent backdrop:bg-neutral-400/20 backdrop:backdrop-blur-sm lg:hidden dark:backdrop:bg-black/40"
>
  <div class="min-h-full w-full max-w-xs bg-paper px-4 pb-12 pt-5 sm:px-6 dark:bg-neutral-900">
    <div class="flex items-center justify-between">
      <a href={import.meta.env.BASE_URL} aria-label="Home page">
        <Logomark class="h-9 w-9 lg:hidden" />
      </a>
      <button type="button" data-mobile-nav-close aria-label="Close navigation">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6 stroke-neutral-900 dark:stroke-neutral-200">
          <path d="M6 6l12 12M6 18 18 6" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>
    </div>
    <Navigation class="mt-5 px-1" />
  </div>
</dialog>

<script>
  function initMobileNav() {
    const openBtn = document.querySelector('[data-mobile-nav-open]')
    const closeBtn = document.querySelector('[data-mobile-nav-close]')
    const dialog = document.querySelector<HTMLDialogElement>('[data-mobile-nav-dialog]')
    if (!openBtn || !dialog) return

    openBtn.addEventListener('click', () => dialog.showModal())
    closeBtn?.addEventListener('click', () => dialog.close())
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close()
    })
    // Close when navigating to a section on the same page.
    dialog.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => dialog.close()),
    )
  }

  initMobileNav()
  document.addEventListener('astro:after-swap', initMobileNav)
</script>
