---
import type { MarkdownHeading } from 'astro'
import BaseLayout from './BaseLayout.astro'
import DocsHeader from '@/components/DocsHeader.astro'
import Prose from '@/components/Prose.astro'
import PrevNextLinks from '@/components/PrevNextLinks.astro'
import TableOfContents from '@/components/TableOfContents.astro'
import type { DocPage } from '@/lib/docs'

interface Props {
  title?: string
  eyebrow?: string
  description?: string
  headings: MarkdownHeading[]
  prev?: DocPage
  next?: DocPage
}

const { title, eyebrow, description, headings, prev, next } = Astro.props
---

<BaseLayout title={title} description={description}>
  <div class="min-w-0 max-w-2xl flex-auto px-4 py-16 lg:max-w-none lg:pl-8 lg:pr-0 xl:px-16">
    <article>
      <DocsHeader title={title} eyebrow={eyebrow} />
      <Prose>
        <slot />
      </Prose>
    </article>
    <PrevNextLinks prev={prev} next={next} />
  </div>
  <TableOfContents headings={headings} />
</BaseLayout>
